{
  "buildCommand": "export LANG=en_US.UTF-8 && export JEKYLL_ENV=production && bundle install && bundle exec jekyll build",
  "outputDirectory": "_site",
  "functions": {
    "api/index.py": {
      "runtime": "@vercel/python@4.3.1"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/api",
      "destination": "/api/index.py"
    }
  ]
}